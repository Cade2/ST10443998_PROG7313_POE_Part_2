<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorAppBackground">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/colorPrimary"
        app:title="@string/title_spending"
        app:titleTextColor="@color/white" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_md">

            <!-- Date range row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/spacing_md">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_start_date"
                    style="@style/StashTextInput"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="@string/hint_start_date"
                    android:layout_marginEnd="@dimen/spacing_xs"
                    app:endIconMode="custom"
                    app:endIconDrawable="@drawable/ic_calendar">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_start_date"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:focusable="false"
                        android:clickable="true"
                        android:inputType="none" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_end_date"
                    style="@style/StashTextInput"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="@string/hint_end_date"
                    android:layout_marginStart="@dimen/spacing_xs"
                    app:endIconMode="custom"
                    app:endIconDrawable="@drawable/ic_calendar">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_end_date"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:focusable="false"
                        android:clickable="true"
                        android:inputType="none" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- Chart area card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardBackgroundColor="@color/colorSurface"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <com.github.mikephil.charting.charts.BarChart
                        android:id="@+id/bar_chart"
                        android:layout_width="match_parent"
                        android:layout_height="280dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Empty state -->
            <LinearLayout
                android:id="@+id/layout_empty_state"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="@dimen/spacing_xl"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/empty_state_no_data"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="@dimen/text_body"
                    android:gravity="center" />
            </LinearLayout>

            <!-- Legend header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_legend"
                android:textSize="@dimen/text_body"
                android:textStyle="bold"
                android:textColor="@color/colorOnSurface"
                android:layout_marginBottom="@dimen/spacing_sm" />

            <!-- Legend items -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/colorSurface"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <!-- Groceries -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="@dimen/spacing_sm">
                        <View android:layout_width="@dimen/category_dot_size" android:layout_height="@dimen/category_dot_size" android:background="@drawable/bg_circle" android:backgroundTint="@color/categoryGroceries" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/category_groceries" android:textColor="@color/colorOnSurface" android:textSize="@dimen/text_md" android:layout_marginStart="@dimen/spacing_sm" />
                    </LinearLayout>
                    <!-- Transport -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="@dimen/spacing_sm">
                        <View android:layout_width="@dimen/category_dot_size" android:layout_height="@dimen/category_dot_size" android:background="@drawable/bg_circle" android:backgroundTint="@color/categoryTransport" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/category_transport" android:textColor="@color/colorOnSurface" android:textSize="@dimen/text_md" android:layout_marginStart="@dimen/spacing_sm" />
                    </LinearLayout>
                    <!-- Entertainment -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="@dimen/spacing_sm">
                        <View android:layout_width="@dimen/category_dot_size" android:layout_height="@dimen/category_dot_size" android:background="@drawable/bg_circle" android:backgroundTint="@color/categoryEntertainment" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/category_entertainment" android:textColor="@color/colorOnSurface" android:textSize="@dimen/text_md" android:layout_marginStart="@dimen/spacing_sm" />
                    </LinearLayout>
                    <!-- Utilities -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="@dimen/spacing_sm">
                        <View android:layout_width="@dimen/category_dot_size" android:layout_height="@dimen/category_dot_size" android:background="@drawable/bg_circle" android:backgroundTint="@color/categoryUtilities" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/category_utilities" android:textColor="@color/colorOnSurface" android:textSize="@dimen/text_md" android:layout_marginStart="@dimen/spacing_sm" />
                    </LinearLayout>
                    <!-- Dining -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                        <View android:layout_width="@dimen/category_dot_size" android:layout_height="@dimen/category_dot_size" android:background="@drawable/bg_circle" android:backgroundTint="@color/categoryDining" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/category_dining" android:textColor="@color/colorOnSurface" android:textSize="@dimen/text_md" android:layout_marginStart="@dimen/spacing_sm" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
