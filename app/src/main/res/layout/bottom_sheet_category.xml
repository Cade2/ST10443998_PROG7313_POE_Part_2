<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="@dimen/spacing_lg"
    android:background="@color/colorSurface">

    <!-- Title -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/title_add_category"
        android:textColor="@color/colorPrimary"
        android:textSize="@dimen/text_title"
        android:textStyle="bold"
        android:layout_marginBottom="@dimen/spacing_md" />

    <!-- Category name input -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_category_name"
        style="@style/StashTextInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/hint_category_name"
        android:layout_marginBottom="@dimen/spacing_md">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_category_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:imeOptions="actionDone" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Colour picker label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_pick_colour"
        android:textColor="@color/colorOnSurface"
        android:textSize="@dimen/text_md"
        android:textStyle="bold"
        android:layout_marginBottom="@dimen/spacing_sm" />

    <!-- Colour picker row -->
    <LinearLayout
        android:id="@+id/colour_picker_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="@dimen/spacing_md">

        <View android:id="@+id/colour_1" android:layout_width="@dimen/colour_picker_circle_size" android:layout_height="@dimen/colour_picker_circle_size" android:background="@drawable/bg_circle" android:backgroundTint="@color/categoryGroceries" android:layout_marginEnd="@dimen/spacing_sm" android:clickable="true" android:focusable="true" />
        <View android:id="@+id/colour_2" android:layout_width="@dimen/colour_picker_circle_size" android:layout_height="@dimen/colour_picker_circle_size" android:background="@drawable/bg_circle" android:backgroundTint="@color/categoryTransport" android:layout_marginEnd="@dimen/spacing_sm" android:clickable="true" android:focusable="true" />
        <View android:id="@+id/colour_3" android:layout_width="@dimen/colour_picker_circle_size" android:layout_height="@dimen/colour_picker_circle_size" android:background="@drawable/bg_circle" android:backgroundTint="@color/categoryEntertainment" android:layout_marginEnd="@dimen/spacing_sm" android:clickable="true" android:focusable="true" />
        <View android:id="@+id/colour_4" android:layout_width="@dimen/colour_picker_circle_size" android:layout_height="@dimen/colour_picker_circle_size" android:background="@drawable/bg_circle" android:backgroundTint="@color/categoryUtilities" android:layout_marginEnd="@dimen/spacing_sm" android:clickable="true" android:focusable="true" />
        <View android:id="@+id/colour_5" android:layout_width="@dimen/colour_picker_circle_size" android:layout_height="@dimen/colour_picker_circle_size" android:background="@drawable/bg_circle" android:backgroundTint="@color/categoryDining" android:layout_marginEnd="@dimen/spacing_sm" android:clickable="true" android:focusable="true" />
        <View android:id="@+id/colour_6" android:layout_width="@dimen/colour_picker_circle_size" android:layout_height="@dimen/colour_picker_circle_size" android:background="@drawable/bg_circle" android:backgroundTint="@color/colorAccent" android:clickable="true" android:focusable="true" />
    </LinearLayout>

    <!-- Buttons row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="@dimen/spacing_md">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cancel"
            style="@style/StashButton.Outlined"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="1"
            android:text="@string/btn_cancel"
            android:layout_marginEnd="@dimen/spacing_xs" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save"
            style="@style/StashButton.Primary"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="1"
            android:text="@string/btn_save"
            android:layout_marginStart="@dimen/spacing_xs" />
    </LinearLayout>

</LinearLayout>
