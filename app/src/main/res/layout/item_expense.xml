<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_sm"
    app:cardBackgroundColor="@color/colorSurface"
    app:cardCornerRadius="@dimen/card_corner_radius_sm"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Coloured left border -->
        <View
            android:id="@+id/view_category_border"
            android:layout_width="@dimen/expense_border_width"
            android:layout_height="match_parent"
            android:background="@color/categoryGroceries" />

        <!-- Content -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="@dimen/spacing_md">

            <!-- Category name and amount row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_category"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Groceries"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="@dimen/text_sm"
                    android:textAllCaps="true" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <!-- Amount -->
                <TextView
                    android:id="@+id/tv_amount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="R245.00"
                    android:textColor="@color/colorPrimary"
                    android:textSize="@dimen/text_body"
                    android:textStyle="bold" />

                <!-- Camera icon if photo attached -->
                <ImageView
                    android:id="@+id/iv_photo_indicator"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_camera"
                    android:contentDescription="@string/content_description_camera"
                    android:layout_marginStart="@dimen/spacing_xs"
                    android:visibility="visible" />
            </LinearLayout>

            <!-- Description -->
            <TextView
                android:id="@+id/tv_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Weekly grocery run"
                android:textColor="@color/colorOnSurface"
                android:textSize="@dimen/text_md"
                android:layout_marginTop="@dimen/spacing_xs" />

            <!-- Date -->
            <TextView
                android:id="@+id/tv_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12 Mar 2026"
                android:textColor="@color/colorTextSecondary"
                android:textSize="@dimen/text_sm"
                android:layout_marginTop="@dimen/spacing_xs" />
        </LinearLayout>
    </LinearLayout>

</androidx.cardview.widget.CardView>
