<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/spacing_xs"
    app:cardBackgroundColor="@color/colorSurface"
    app:cardCornerRadius="@dimen/card_corner_radius"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="@dimen/spacing_md">

        <!-- Badge icon -->
        <ImageView
            android:id="@+id/iv_badge_icon"
            android:layout_width="@dimen/badge_icon_size"
            android:layout_height="@dimen/badge_icon_size"
            android:src="@drawable/ic_badge_star"
            android:contentDescription="Badge Icon" />

        <!-- Badge name -->
        <TextView
            android:id="@+id/tv_badge_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="First Save"
            android:textColor="@color/colorOnSurface"
            android:textSize="@dimen/text_md"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="@dimen/spacing_xs" />

        <!-- Badge description -->
        <TextView
            android:id="@+id/tv_badge_description"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Saved your first expense"
            android:textColor="@color/colorTextSecondary"
            android:textSize="@dimen/text_sm"
            android:gravity="center"
            android:layout_marginTop="@dimen/spacing_xs" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
